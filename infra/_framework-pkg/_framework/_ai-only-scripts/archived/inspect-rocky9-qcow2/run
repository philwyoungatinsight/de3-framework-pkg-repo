#!/usr/bin/env bash
# Inspect Rocky 9 GenericCloud qcow2 partition layout on maas-region-1.
# Reports partition layout and root filesystem contents.
# Usage: ./run
set -euo pipefail
function handle_error {
    local exit_status=$?
    echo "An error occurred on line $LINENO: $BASH_COMMAND"
    exit $exit_status
}
trap handle_error ERR

GIT_ROOT="$(git rev-parse --show-toplevel)"
# shellcheck source=/dev/null
. "$GIT_ROOT/set_env.sh"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
# shellcheck source=/dev/null
. "$_UTILITIES_DIR/bash/init.sh"

export PYTHON_VERSION='python3.12'
INVENTORY_FILE="${_DYNAMIC_DIR}/ansible/inventory/hosts.yml"

if [ ! -f "${INVENTORY_FILE}" ]; then
    echo "Inventory not found — generating..."
    "$_GENERATE_INVENTORY" --build
fi

_activate_ansible_locally "$SCRIPT_DIR"

ansible-playbook \
  -i "${INVENTORY_FILE}" \
  "$SCRIPT_DIR/playbook.yaml"
