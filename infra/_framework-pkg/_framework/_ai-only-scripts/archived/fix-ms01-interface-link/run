#!/usr/bin/env bash
# Fix ms01-01 MaaS interface link state after force-release left stale IP reservations.
# Run when maas_instance.this deploy fails with "has a reserved ip but no link to subnet".
set -euo pipefail

GIT_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$GIT_ROOT/set_env.sh"

VENV_BASE="$SCRIPT_DIR"
# shellcheck source=/dev/null
_activate_ansible_locally "$VENV_BASE"

INVENTORY="$_DYNAMIC_DIR/ansible/inventory/hosts.yml"

if [[ ! -f "$INVENTORY" ]]; then
  echo "Regenerating Ansible inventory..."
  "$_GENERATE_INVENTORY" --test
fi

export ANSIBLE_HOST_KEY_CHECKING=False
export ANSIBLE_PYTHON_INTERPRETER=auto
export SCRIPT_DIR
# _ANSIBLE_ROLES_DIR is set by set_env.sh — do not override

echo "=== Fixing ms01-01 MaaS interface links ==="
ansible-playbook \
  --inventory "$INVENTORY" \
  "$SCRIPT_DIR/playbook.yaml" \
  "$@"
