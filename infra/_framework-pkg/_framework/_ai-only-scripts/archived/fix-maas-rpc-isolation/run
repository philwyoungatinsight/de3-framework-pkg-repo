#!/usr/bin/env bash
set -euo pipefail

GIT_ROOT="$(git rev-parse --show-toplevel)"
export GIT_ROOT

# shellcheck source=/dev/null
. "$GIT_ROOT/set_env.sh"

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"

# shellcheck source=/dev/null
. "$_UTILITIES_DIR/bash/init.sh"

export PYTHON_VERSION='python3.12'
_activate_ansible_locally "$SCRIPT_DIR"

# _activate_ansible_locally exports ANSIBLE_PYTHON_INTERPRETER pointing at
# the local .venv; override it so the remote host uses its own system Python.
ansible-playbook \
  -i "10.0.10.11," \
  -e "ansible_user=ubuntu ansible_python_interpreter=/usr/bin/python3 ansible_ssh_common_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'" \
  "${SCRIPT_DIR}/playbook.yaml" \
  "$@"
