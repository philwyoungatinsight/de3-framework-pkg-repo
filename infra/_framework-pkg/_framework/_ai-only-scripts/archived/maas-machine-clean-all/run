#!/usr/bin/env bash
# Clean all MaaS machine state for a full-reset build cycle.
#
# What this does (in order):
#   1. Power off each physical machine via smart plug / AMT
#   2. Delete each machine from MaaS (force-Ready first via DB, then delete)
#   3. Remove all Terraform state for each machine unit and
#      the configure-physical-machines aggregating unit
#
# What this does NOT do:
#   - Rebuild or reconfigure the MaaS server
#   - Wipe physical disks (use playbook.wipe-hosts.yaml for that)
#
# After this script succeeds:
#   - All machines are powered off
#   - No machine entries exist in MaaS
#   - All machine Terraform state is gone
#   - Power the machines on manually (or re-run to trigger PXE enlistment)
#   - Then run: ./run --apply --start-at 9   (wave pxe.maas.machine-entries)
#
# Options (passed through to ansible-playbook):
#   --extra-vars "skip_power_off=true"   Skip the power-off step
#   --extra-vars "dry_run=true"          Show what would be done, no changes

set -euo pipefail

GIT_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=/dev/null
source "$GIT_ROOT/set_env.sh"
# shellcheck source=/dev/null
source "$_UTILITIES_DIR/bash/init.sh"

VENV_BASE="$SCRIPT_DIR"
# shellcheck source=/dev/null
_activate_ansible_locally "$VENV_BASE"

INVENTORY="$_DYNAMIC_DIR/ansible/inventory/hosts.yml"

if [[ ! -f "$INVENTORY" ]]; then
  echo "Regenerating Ansible inventory..."
  "$_GENERATE_INVENTORY" --test
fi

export ANSIBLE_HOST_KEY_CHECKING=False
export ANSIBLE_PYTHON_INTERPRETER=auto
# _ANSIBLE_ROLES_DIR is set by set_env.sh — do not override

echo "=== MaaS machine clean-all ==="
ansible-playbook \
  --inventory "$INVENTORY" \
  "$SCRIPT_DIR/playbook.yaml" \
  "$@"
