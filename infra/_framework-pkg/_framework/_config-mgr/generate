#!/bin/bash
# Minimal entry point for config-mgr generate — does NOT source set_env.sh.
# Called from set_env.sh itself (which would cause infinite recursion if we used run).
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"

# Activate venv if present (same venv as the full run script)
if [[ -d "$SCRIPT_DIR/.venv" ]]; then
    . "$SCRIPT_DIR/.venv/bin/activate"
elif [[ -d "$SCRIPT_DIR/venv" ]]; then
    . "$SCRIPT_DIR/venv/bin/activate"
fi

cd "${SCRIPT_DIR}" && exec python3 -m config_mgr.main generate "$@"
