#!/usr/bin/env python3
"""
wave-mgr — Wave execution engine for the lab stack.

Applies waves, runs tests, and destroys resources.
Invoked directly or via the top-level 'run' script.

USAGE
  wave-mgr -a|--apply                       apply all waves + run tests
  wave-mgr -a|--apply -w <pattern>          apply matching waves + run tests
  wave-mgr -a|--apply -s|--skip-test        apply all waves, skip tests
  wave-mgr -w <pattern>                     shorthand for -a -w <pattern>
  wave-mgr -t|--test                        run test scripts for all waves (no apply)
  wave-mgr -t|--test -w <pattern>           run test scripts for matching waves
  wave-mgr -c|--clean                       destroy all wave resources (reverse order, honours _skip_on_wave_run)
  wave-mgr -c|--clean -w <pattern>          destroy matching waves (reverse order, ignores _skip_on_wave_run)
  wave-mgr -C|--clean-all                   nuclear cleanup via clean-all (prompts "NUKE", no skipping)
  wave-mgr -A|--app <name>                  find _application/<name> under any package and run make
  wave-mgr -u|--unlock-gcs                  delete all stale GCS state locks (.tflock files) and exit
  wave-mgr -l|--list-waves                  print all waves as a colored table and exit
  wave-mgr -l|--list-waves -w <pattern>     print only waves matching pattern
  wave-mgr -l|--list-waves -f json          print as JSON
  wave-mgr -l|--list-waves -f yaml          print as YAML
  wave-mgr -L|--list-waves-status           same as -l but adds Duration and Last-Updated columns

  -s|--skip-test can be combined with -a or -w to skip post-apply tests.
  -i|--ignore-errors can be combined with any mode: log failures and continue
                     instead of aborting. Exits 1 if any step failed.
                     If apply fails for a wave, inventory update and test are
                     skipped for that wave (they depend on apply succeeding).
  -n|--wave-n N      select wave N by number (1-based); equivalent to
                     -w <name-of-wave-N>. -n alone implies --apply.
  -N|--stop-at N     for forward modes (apply/test): process waves 1..N
                     inclusive. For --clean: process waves N..last in reverse
                     order (i.e. the usual reverse traversal, stopping at N).
                     -N alone implies --apply.
  -M|--start-at N    for forward modes (apply/test): skip waves 1..N-1 and
                     start from wave N. For --clean: destroy only waves 1..N-1 in
                     reverse order. Combine with -N/--stop-at to run a range M..N.
                     -M/--start-at alone implies --apply.
  --clean and --clean-all never run tests.
  Wave pattern supports globs: "on_prem.maas.*"

WAVE SELECTION EXAMPLES
  wave-mgr -n 3                             apply wave 3 only (by number)
  wave-mgr -n 3 -c                          destroy wave 3 only
  wave-mgr -N 3                             apply waves 1..3
  wave-mgr -N 3 -c                          destroy waves 3..last in reverse order
  wave-mgr -M 4                             apply waves 4..last (skip 1..3)
  wave-mgr -M 4 -b                          build + apply waves 4..last
  wave-mgr -M 3 -N 6                        apply waves 3..6
  wave-mgr -M 3 -c                          destroy waves 1..2 in reverse order

LOGGING
  All output is ALWAYS logged to a per-run directory:
    $WAVE_LOGS_DIR/<YYYYMMDD-HHMMSS>/
        run.log                     — full stdout+stderr for the entire run
        wave-<name>-apply.log       — terragrunt apply for each wave
        wave-<name>-destroy.log     — terragrunt destroy (--clean mode)
        wave-<name>-precheck.log    — pre_ansible_playbook output
        wave-<name>-test-playbook.log — test_ansible_playbook output
        wave-<name>-inventory.log   — inventory update output
    $WAVE_LOGS_DIR/latest/  — symlink to the most recent run directory

  To watch the current run:
    tail -f $WAVE_LOGS_DIR/latest/run.log
"""

