# ── logging ────────────────────────────────────────────────────────────────────

class _Tee:
    """Write to multiple streams simultaneously."""
    def __init__(self, *streams):
        self.streams = streams

    def write(self, data):
        for s in self.streams:
            s.write(data)

    def flush(self):
        for s in self.streams:
            s.flush()

    def __getattr__(self, name):
        return getattr(self.streams[0], name)


def setup_logging() -> Path:
    wave_logs_dir = os.environ.get("_WAVE_LOGS_DIR")
    if not wave_logs_dir:
        raise RuntimeError("_WAVE_LOGS_DIR is not set — source set_env.sh before running")
    log_base = Path(wave_logs_dir)
    run_id = datetime.datetime.now().strftime('%Y%m%d-%H%M%S')
    log_dir = log_base / run_id
    log_dir.mkdir(parents=True, exist_ok=True)

    latest = log_base / 'latest'
    if latest.is_symlink() or latest.exists():
        latest.unlink()
    latest.symlink_to(log_dir)

    run_log = log_dir / 'run.log'
    log_fh = open(run_log, 'w')
    sys.stdout = _Tee(sys.__stdout__, log_fh)
    sys.stderr = _Tee(sys.__stderr__, log_fh)

    print('=' * 64)
    print(f'  run log directory : {log_dir}')
    print(f'  Full log          : {run_log}')
    print(f'  Follow output     : tail -f {run_log}')
    print('=' * 64)
    print()

    return log_dir


# ── subprocess helper ──────────────────────────────────────────────────────────

def _stream(cmd: list, *, extra_env: dict = None, cwd=None, wave_log: Path = None):
    """
    Run cmd, streaming output to sys.stdout (tee'd to run.log when logging is
    active) and optionally also to wave_log.
    Raises CalledProcessError on non-zero exit.
    """
    env = {**ENV, **(extra_env or {})}
    lf = open(wave_log, 'w') if wave_log else None
    try:
        with subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
            env=env, cwd=str(cwd) if cwd else None,
            text=True, bufsize=1,
        ) as proc:
            for line in proc.stdout:
                sys.stdout.write(line)
                sys.stdout.flush()
                if lf:
                    lf.write(line)
                    lf.flush()
            proc.wait()
            if proc.returncode != 0:
                raise subprocess.CalledProcessError(proc.returncode, cmd)
    finally:
        if lf:
            lf.close()


# ── config ─────────────────────────────────────────────────────────────────────

def load_all_configs() -> dict:
    """Load framework config + all per-package configs.

    Framework config (config/framework.yaml) provides:
      - backend, ssh_config, ansible_inventory, clean_all, pre_apply_unlock
      - waves_ordering: ordered list of wave names

    Per-package configs (infra/<pkg>/_config/<pkg>.yaml) provide:
      - wave definitions (with pre/test playbooks, _skip_on_wave_run, etc.)
      - provider config_params (for lock-key prefix calculation)
      - package metadata (_provides_capability, _requires_capability, etc.)

    Returns a merged cfg dict with assembled 'waves' list (ordered by framework)
    plus '_packages' key for package metadata.
    """
    # Load framework config from split framework_*.yaml files in _config/.
    try:
        cfg = load_framework_config(find_framework_config_dirs(STACK_ROOT))
    except FileNotFoundError as e:
        sys.exit(f'ERROR: {e}')

    packages: dict = {}
    all_wave_defs: dict = {}   # wave_name -> wave dict

    # Load per-package configs — each package's config is named <pkg>.yaml
    for pkg_dir in sorted(p for p in INFRA_DIR.iterdir() if p.is_dir()):
        pkg_name = pkg_dir.name
        pkg_config_file = pkg_dir / '_config' / f'{pkg_name}.yaml'
        if not pkg_config_file.exists():
            continue
        with open(pkg_config_file) as f:
            pkg_raw = yaml.safe_load(f)
        if not pkg_raw:
            continue
        pkg_cfg = pkg_raw.get(pkg_name, {}) or {}

        # Collect package metadata (underscore-prefixed keys)
        packages[pkg_name] = {k: v for k, v in pkg_cfg.items() if k.startswith('_')}

        # Collect wave definitions from this package
        for wave in pkg_cfg.get('waves', []):
            wave_name = wave.get('name')
            if wave_name:
                if wave_name in all_wave_defs:
                    sys.exit(
                        f'ERROR: wave {wave_name!r} is defined in both'
                        f' {all_wave_defs[wave_name]["_pkg"]} and {pkg_name}.'
                        f' Each wave must be defined in exactly one package.'
                    )
                wave = dict(wave)
                wave['_pkg'] = pkg_name  # internal tracking, stripped before use
                all_wave_defs[wave_name] = wave

        # Merge package-level config_params into cfg (used for pre-apply lock key computation)
        for key, params in (pkg_cfg.get('config_params') or {}).items():
            if isinstance(params, dict):
                cfg.setdefault('config_params', {})[key] = params

        # Merge providers into cfg (used for pre-apply lock key computation)
        for prov_name, prov_data in pkg_cfg.get('providers', {}).items():
            cfg.setdefault('providers', {}).setdefault(prov_name, {})
            prov_data = prov_data or {}
            for section, data in prov_data.items():
                if section == 'config_params':
                    cfg['providers'][prov_name].setdefault('config_params', {}).update(data or {})
                else:
                    cfg['providers'][prov_name][section] = data

    # Discover waves_ordering.yaml using the same search dirs as framework_config.py.
    # Later dirs have higher priority; iterate in reverse so the first match is the winner.
    ordering_file = None
    for config_dir in reversed(find_framework_config_dirs(STACK_ROOT)):
        candidate = config_dir / 'waves_ordering.yaml'
        if candidate.exists():
            ordering_file = candidate
            break
    if ordering_file is None:
        sys.exit('ERROR: waves_ordering.yaml not found in any framework config dir')
    with open(ordering_file) as f:
        ordering_raw = yaml.safe_load(f) or {}
    waves_ordering = ordering_raw.get('waves_ordering', [])

    # Assemble waves in declared order. Each entry is {name: ..., <future attrs>}.
    assembled = []
    for entry in waves_ordering:
        wave_name = entry['name'] if isinstance(entry, dict) else entry
        if wave_name in all_wave_defs:
            w = dict(all_wave_defs[wave_name])
            w.pop('_pkg', None)  # remove internal tracking key
            assembled.append(w)
        # Wave in ordering but no package defines it: silently skip
        # (allows adding waves to ordering before implementing them)
    cfg['waves'] = assembled
    cfg['_packages'] = packages
    return cfg


def load_waves() -> list:
    return load_all_configs().get('waves', [])


