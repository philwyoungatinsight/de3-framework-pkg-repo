def _fmt_duration(seconds: float) -> str:
    """Format seconds as a compact human-readable duration.

    Examples: "3h-22m-07s" / "22m-07s" / "7s"
    Leading zero components are suppressed; the last component is always shown.
    """
    s = max(0, int(seconds))
    h, rem = divmod(s, 3600)
    m, sec = divmod(rem, 60)
    if h:
        return f'{h}h-{m:02d}m-{sec:02d}s'
    if m:
        return f'{m}m-{sec:02d}s'
    return f'{sec}s'


def _scan_wave_statuses() -> dict:
    """Scan $_WAVE_LOGS_DIR and return per-wave status, duration, and last-updated.

    Walks log directories newest-first; for each wave name, resolves each log
    type (main apply/destroy, precheck, test-playbook) independently from the
    newest directory that contains that log file. Mirrors the logic in the GUI's
    refresh_wave_log_statuses(). Returns:
      { wave_name: { 'status': str, 'pre_status': str, 'test_status': str,
                     'duration': str, 'last_updated': str } }
    Status values: "ok" | "fail" | "running" | "none"
    """
    import re
    wave_logs_dir = os.environ.get("_WAVE_LOGS_DIR")
    if not wave_logs_dir:
        raise RuntimeError("_WAVE_LOGS_DIR is not set — source set_env.sh before running")
    log_base = Path(wave_logs_dir)
    if not log_base.exists():
        return {}
    ts_pattern = re.compile(r'^\d{8}-\d{6}$')
    dirs = sorted(
        [d for d in log_base.iterdir()
         if d.is_dir() and not d.is_symlink() and ts_pattern.match(d.name)],
        key=lambda d: d.name,
        reverse=True,
    )

    # Track which wave names have been resolved for each log type
    main_found: set = set()
    pre_found:  set = set()
    test_found: set = set()
    statuses: dict = {}
    now = datetime.datetime.now()

    _RUNNING_THRESHOLD_SECS = 300

    def _wave_status(run_content, wave_name, action, run_log_mtime=None):
        done_marker = f'--- [{wave_name}] {action} done ---'
        fail_marker = f'[{wave_name}] {action} failed'
        if done_marker in run_content:
            return 'ok'
        if fail_marker in run_content or 'ERROR: command failed' in run_content:
            return 'fail'
        if run_log_mtime is not None:
            age = (now - datetime.datetime.fromtimestamp(run_log_mtime)).total_seconds()
            if age < _RUNNING_THRESHOLD_SECS:
                return 'running'
        return 'fail'

    for d in dirs:
        try:
            start_dt = datetime.datetime.strptime(d.name, '%Y%m%d-%H%M%S')
        except ValueError:
            start_dt = None

        run_log = d / 'run.log'
        run_content = run_log.read_text(errors='replace') if run_log.exists() else ''
        try:
            run_log_mtime = run_log.stat().st_mtime if run_log.exists() else None
        except OSError:
            run_log_mtime = None

        for log_file in sorted(d.iterdir()):
            fname = log_file.name

            # ── main: apply / destroy ──────────────────────────────────────
            mm = re.match(r'^wave-(.+)-(apply|destroy)\.log$', fname)
            if mm:
                wave_name = mm.group(1)
                action    = mm.group(2)
                if wave_name not in main_found:
                    main_found.add(wave_name)
                    try:
                        end_dt = datetime.datetime.fromtimestamp(log_file.stat().st_mtime)
                    except OSError:
                        end_dt = None
                    entry = statuses.setdefault(wave_name, {})
                    entry['status'] = _wave_status(run_content, wave_name, action, run_log_mtime)
                    entry['duration'] = (
                        _fmt_duration((end_dt - start_dt).total_seconds())
                        if start_dt and end_dt else ''
                    )
                    entry['last_updated'] = (
                        _fmt_duration((now - end_dt).total_seconds())
                        if end_dt else ''
                    )
                continue

            # ── precheck ──────────────────────────────────────────────────
            mp = re.match(r'^wave-(.+)-precheck\.log$', fname)
            if mp:
                wave_name = mp.group(1)
                if wave_name not in pre_found:
                    pre_found.add(wave_name)
                    entry = statuses.setdefault(wave_name, {})
                    entry['pre_status'] = _wave_status(run_content, wave_name, 'precheck', run_log_mtime)
                continue

            # ── test-playbook ──────────────────────────────────────────────
            mt = re.match(r'^wave-(.+)-test-playbook\.log$', fname)
            if mt:
                wave_name = mt.group(1)
                if wave_name not in test_found:
                    test_found.add(wave_name)
                    entry = statuses.setdefault(wave_name, {})
                    entry['test_status'] = _wave_status(run_content, wave_name, 'test-playbook', run_log_mtime)

    return statuses


def list_waves(all_waves: list, wave_filter: str, fmt: str, statuses: dict = None):
    waves = [
        w for w in all_waves
        if not wave_filter or fnmatch.fnmatch(w['name'], wave_filter)
    ]

    if fmt == 'json':
        if statuses:
            for w in waves:
                s = statuses.get(w.get('name', ''), {})
                if s:
                    w = dict(w, **s)
        print(json.dumps(waves, indent=2))
        return

    if fmt == 'yaml':
        if statuses:
            waves = [dict(w, **statuses.get(w.get('name', ''), {})) for w in waves]
        print(yaml.dump(waves, default_flow_style=False), end='')
        return

    # Colored table
    use_color = sys.__stdout__.isatty() and not os.environ.get('NO_COLOR')
    BOLD    = '\033[1m'  if use_color else ''
    RESET   = '\033[0m'  if use_color else ''
    CYAN    = '\033[36m' if use_color else ''
    GREEN   = '\033[32m' if use_color else ''
    YELLOW  = '\033[33m' if use_color else ''
    RED     = '\033[31m' if use_color else ''
    DIM     = '\033[2m'  if use_color else ''
    MAGENTA = '\033[35m' if use_color else ''

    def cell(text, width, color=''):
        padded = text.ljust(width)
        return f'{color}{padded}{RESET}' if color else padded

    def rcell(text, width, color=''):
        padded = text.rjust(width)
        return f'{color}{padded}{RESET}' if color else padded

    # Status symbol + color for "ok"/"fail"/"running"/"none"/""
    _STATUS_ICON = {
        'ok':      ('✓', GREEN),
        'fail':    ('✗', RED),
        'running': ('⟳', YELLOW),
        'none':    ('·', DIM),
        '':        ('·', DIM),
    }

    def status_icon(s):
        sym, col = _STATUS_ICON.get(s, ('?', DIM))
        return f'{col}{sym}{RESET}' if col else sym

    rows = [
        (
            w.get('name', ''),
            w.get('pre_ansible_playbook', ''),
            w.get('test_ansible_playbook', ''),
            w.get('test_action', ''),
            '✓' if w.get('update_inventory') else '',
        )
        for w in waves
    ]

    # "P·R·T" status cell: 5 visible chars ("P R T" with spaces)
    STATUS_HDR = 'P R T'
    STATUS_W   = len(STATUS_HDR)  # 5

    if statuses:
        st_rows = [
            (
                statuses.get(w.get('name', ''), {}).get('pre_status',  ''),
                statuses.get(w.get('name', ''), {}).get('status',      ''),
                statuses.get(w.get('name', ''), {}).get('test_status', ''),
                statuses.get(w.get('name', ''), {}).get('duration',    ''),
                statuses.get(w.get('name', ''), {}).get('last_updated',''),
            )
            for w in waves
        ]
        HEADERS = ('#', 'Wave', 'Pre-Run Ansible Playbook',
                   'Test Ansible Playbook', 'Test Action', 'Inv',
                   STATUS_HDR, 'Duration', 'Last Updated')
        W = [
            max(len(HEADERS[0]), len(str(len(rows)))),
            max(len(HEADERS[1]), max((len(r[0]) for r in rows), default=0)),
            max(len(HEADERS[2]), max((len(r[1]) for r in rows), default=0)),
            max(len(HEADERS[3]), max((len(r[2]) for r in rows), default=0)),
            max(len(HEADERS[4]), max((len(r[3]) for r in rows), default=0)),
            max(len(HEADERS[5]), max((len(r[4]) for r in rows), default=0)),
            STATUS_W,
            max(len(HEADERS[7]), max((len(s[3]) for s in st_rows), default=0)),
            max(len(HEADERS[8]), max((len(s[4]) for s in st_rows), default=0)),
        ]
    else:
        st_rows = None
        HEADERS = ('#', 'Wave', 'Pre-Run Ansible Playbook',
                   'Test Ansible Playbook', 'Test Action', 'Inv')
        W = [
            max(len(HEADERS[0]), len(str(len(rows)))),
            max(len(HEADERS[1]), max((len(r[0]) for r in rows), default=0)),
            max(len(HEADERS[2]), max((len(r[1]) for r in rows), default=0)),
            max(len(HEADERS[3]), max((len(r[2]) for r in rows), default=0)),
            max(len(HEADERS[4]), max((len(r[3]) for r in rows), default=0)),
            max(len(HEADERS[5]), max((len(r[4]) for r in rows), default=0)),
        ]

    divider = '┼'.join('─' * (w + 2) for w in W)
    header = ' │ '.join(
        (HEADERS[i].rjust(W[i]) if i == 0 else HEADERS[i].ljust(W[i]))
        for i in range(len(HEADERS))
    )
    print(f'{BOLD} {header} {RESET}')
    print(divider)

    for i, (name, pre_pb, test_pb, test_a, inv) in enumerate(rows, 1):
        cols = [
            str(i).rjust(W[0]),
            cell(name,    W[1], CYAN),
            cell(pre_pb,  W[2], GREEN  if pre_pb  else DIM),
            cell(test_pb, W[3], GREEN  if test_pb else DIM),
            cell(test_a,  W[4], YELLOW if test_a  else DIM),
            cell(inv,     W[5], GREEN  if inv     else DIM),
        ]
        if st_rows:
            pre_s, run_s, tst_s, dur, upd = st_rows[i - 1]
            # "P R T" — three icons with a space between each; always 5 visible chars
            status_cell = f'{status_icon(pre_s)} {status_icon(run_s)} {status_icon(tst_s)}'
            cols.append(status_cell)
            cols.append(rcell(dur, W[7], MAGENTA if dur else DIM))
            cols.append(rcell(upd, W[8], DIM))
        print(f' {cols[0]} │ {" │ ".join(cols[1:])} ')

    if wave_filter:
        print(f'\n{DIM}filter: {wave_filter}  ({len(waves)} of {len(all_waves)} waves){RESET}')
    else:
        print(f'\n{DIM}{len(waves)} wave{"s" if len(waves) != 1 else ""}{RESET}')


# ── arg parsing ────────────────────────────────────────────────────────────────

def find_application(name: str) -> Path:
    """Search all _application/<name> directories under infra packages.

    Errors and exits if:
      - no match is found
      - more than one match is found (name collision across packages)
    Returns the matching application directory path on success.
    """
    matches = [
        d
        for pkg_dir in INFRA_DIR.iterdir()
        if pkg_dir.is_dir()
        for d in [pkg_dir / '_application' / name]
        if d.is_dir()
    ]
    if len(matches) == 0:
        print(f'ERROR: no _application/{name!r} found under any package in {INFRA_DIR}', file=sys.stderr)
        sys.exit(1)
    if len(matches) > 1:
        paths = '\n  '.join(str(m) for m in matches)
        print(
            f'ERROR: ambiguous app name {name!r} — found in multiple packages:\n  {paths}',
            file=sys.stderr,
        )
        sys.exit(1)
    return matches[0]


def parse_args():
    p = argparse.ArgumentParser(
        prog='wave-mgr',
        description='Wave execution engine — applies waves, runs tests, destroys resources.',
        add_help=True,
    )
    p.add_argument('-a', '--apply',           action='store_true', help='apply all waves + run tests')
    p.add_argument('-t', '--test',            action='store_true', help='run tests for all waves (no apply)')
    p.add_argument('-c', '--clean',           action='store_true', help='destroy all wave resources (reverse order)')
    p.add_argument('-C', '--clean-all',       action='store_true', dest='clean_all', help='nuclear cleanup via clean-all')
    p.add_argument('-u', '--unlock-gcs',      action='store_true', dest='unlock_gcs',     help='delete all stale GCS state locks (.tflock files) and exit')
    p.add_argument('-A', '--app',             metavar='NAME',      dest='app',        help='find _application/<NAME> under any package and run make')
    p.add_argument('-l', '--list-waves',      action='store_true', dest='list_waves', help='print waves and exit')
    p.add_argument('-L', '--list-waves-status', action='store_true', dest='list_waves_status', help='like -l but adds Duration and Last-Updated columns from run logs')
    p.add_argument('-w', '--wave',           metavar='PATTERN',   help='wave name glob filter (-w alone implies --apply)')
    p.add_argument('-n', '--wave-n',         type=int, metavar='N', dest='wave_n',
                   help='select wave N by number (1-based); equivalent to -w <name>. -n alone implies --apply')
    p.add_argument('-N', '--stop-at',        type=int, metavar='N', dest='stop_at',
                   help='process waves 1..N (forward) or N..last (clean). -N alone implies --apply')
    p.add_argument('-M', '--start-at',      type=int, metavar='N', dest='start_at',
                   help='skip waves 1..N-1 and start from wave N (forward). For clean: destroy only 1..N-1. -M/--start-at alone implies --apply')
    p.add_argument('-s', '--skip-test',      action='store_true', dest='skip_test',     help='skip post-apply tests')
    p.add_argument('-i', '--ignore-errors',  action='store_true', dest='ignore_errors', help='continue past failures; exit 1 at end if any step failed')
    p.add_argument('-f', '--format',         choices=['table', 'json', 'yaml'], default='table', help='output format for --list-waves')

    args = p.parse_args()

    # Mutual-exclusion checks
    if args.wave_n is not None and args.wave is not None:
        p.error('-n/--wave-n and -w/--wave cannot be combined')
    if args.wave_n is not None and args.stop_at is not None:
        p.error('-n/--wave-n and -N/--stop-at cannot be combined')
    if args.stop_at is not None and args.wave is not None:
        p.error('-N/--stop-at and -w/--wave cannot be combined')
    if args.start_at is not None and args.wave is not None:
        p.error('--start-at and -w/--wave cannot be combined')
    if args.start_at is not None and args.wave_n is not None:
        p.error('--start-at and -n/--wave-n cannot be combined')

    # -w / -n / -N / --start-at alone are shorthand for --apply
    mode_flags = [args.apply, args.test, args.clean,
                  args.clean_all, args.unlock_gcs, args.list_waves, args.list_waves_status]
    implied = args.wave or args.wave_n is not None or args.stop_at is not None or args.start_at is not None
    if args.app is not None:
        if any(mode_flags) or implied:
            p.error('-A/--app cannot be combined with other modes')
    elif implied and not any(mode_flags):
        args.apply = True
    elif not any(mode_flags) and not implied:
        p.print_help()
        sys.exit(0)

    return args


# ── main ───────────────────────────────────────────────────────────────────────

def _warn(msg: str):
    print(f'\nWARN: {msg}', file=sys.stderr)


def main():
    args = parse_args()

    # ── app (no logging, run make in _application/<name>) ──
    # Handled before load_all_configs() because apps need no wave config.
    if args.app is not None:
        app_dir = find_application(args.app)
        print(f'Running make in {app_dir}')
        result = subprocess.run(['make'], cwd=str(app_dir), env=ENV)
        sys.exit(result.returncode)

    cfg = load_all_configs()
    all_waves = cfg.get('waves', [])
    ignore = args.ignore_errors
    failures = []
    pre_apply_unlock = cfg.get('pre_apply_unlock', True)
    gcs_bucket = get_gcs_bucket(cfg) if cfg.get('backend', {}).get('type') == 'gcs' else ''

    # ── list-waves (no logging) ──
    if args.list_waves or args.list_waves_status:
        display = all_waves
        if args.stop_at is not None:
            n = args.stop_at
            if n < 1 or n > len(all_waves):
                print(f'ERROR: -N {n} out of range (1..{len(all_waves)})', file=sys.stderr)
                sys.exit(1)
            display = all_waves[:n]
        statuses = _scan_wave_statuses() if args.list_waves_status else None
        list_waves(display, args.wave or '', args.format, statuses)
        return

    # ── unlock-gcs only (no logging) ──
    if args.unlock_gcs:
        unlock_all_gcs_locks(get_gcs_bucket(cfg))
        return

    # Wave ordering and package validation only matter when applying waves.
    validate_packages(cfg)

    # ── Resolve -n (wave by number) → args.wave ──
    if args.wave_n is not None:
        n = args.wave_n
        if n < 1 or n > len(all_waves):
            print(f'ERROR: -n {n} out of range (1..{len(all_waves)})', file=sys.stderr)
            sys.exit(1)
        args.wave = all_waves[n - 1]['name']

    # ── clean-all (no logging, interactive) ──
    # Run directly with inherited stdout/stderr so confirm_destructive() can
    # print the prompt to the terminal and read the user's "NUKE" reply.
    # Do NOT use _stream() here — piping stdout breaks the interactive prompt.
    if args.clean_all:
        if not NUKE_ALL.is_file():
            print(f'ERROR: clean-all not found: {NUKE_ALL}', file=sys.stderr)
            sys.exit(1)
        result = subprocess.run([str(NUKE_ALL)], env=ENV)
        sys.exit(result.returncode)
        return

    # ── all other modes: set up logging first ──
    log_dir = setup_logging()

    # ── filter + order waves ──
    waves = all_waves
    if args.wave:
        waves = [w for w in waves if fnmatch.fnmatch(w['name'], args.wave)]
    if args.start_at is not None:
        n = args.start_at
        if n < 1 or n > len(all_waves):
            print(f'ERROR: --start-at {n} out of range (1..{len(all_waves)})', file=sys.stderr)
            sys.exit(1)
        # Forward: waves N..last.  Clean: waves 1..N-1 (reverse applied below).
        waves = all_waves[n - 1:] if not args.clean else all_waves[:n - 1]
    if args.stop_at is not None:
        n = args.stop_at
        if n < 1 or n > len(all_waves):
            print(f'ERROR: -N {n} out of range (1..{len(all_waves)})', file=sys.stderr)
            sys.exit(1)
        # Forward: waves 1..N.  Clean: waves N..last (reverse applied below).
        # When combined with --start-at, waves is already filtered to start_at..last;
        # cap it to start_at..(N) by re-slicing from all_waves.
        if args.start_at is not None:
            waves = all_waves[args.start_at - 1:n]
        else:
            waves = all_waves[:n] if not args.clean else all_waves[n - 1:]
    # Honour _skip_on_wave_run unless the user targeted a specific wave with -w.
    # Applies to both build and clean — these waves are never run by the default runner.
    if not args.wave:
        waves = [w for w in waves if not w.get('_skip_on_wave_run')]
    if args.clean:
        waves = list(reversed(waves))

    partial_run = len(waves) < len(all_waves)

    print('=== lab-stack wave runner ===\n')

    for w in waves:
        name        = w['name']
        pre_pb      = w.get('pre_ansible_playbook', '')
        test_pb     = w.get('test_ansible_playbook', '')
        test_action = w.get('test_action', '')
        update_inv  = w.get('update_inventory', False)
        max_retries        = w.get('max_retries', 0)
        retry_delay        = w.get('retry_delay_seconds', 0)

        print(f'\n{"═" * 64}')
        print(f'  Wave: {name}')
        print(f'{"═" * 64}')

        # ── clean mode ──
        if args.clean:
            try:
                run_tg('destroy', name, log_dir)
            except subprocess.CalledProcessError as e:
                if not ignore:
                    raise
                _warn(f'[{name}] destroy failed (exit {e.returncode}) — continuing')
                failures.append(f'{name}:destroy')
            continue

        # ── test-only mode ──
        if args.test:
            try:
                if test_pb:
                    run_ansible_playbook(test_pb, name, 'test-playbook', log_dir)
                elif test_action == 'reapply':
                    print(f'\n--- [{name}] test: reapply (idempotency check) ---')
                    run_tg('apply', name, log_dir)
                else:
                    print('  (no test configured for this wave)')
            except subprocess.CalledProcessError as e:
                if not ignore:
                    raise
                _warn(f'[{name}] test failed (exit {e.returncode}) — continuing')
                failures.append(f'{name}:test')
            continue

        # ── apply + test with retry ──
        # max_retries: number of additional attempts after the first.
        # The precheck, apply, and test all run inside the retry loop.
        # If the precheck fails and retries remain, the whole wave retries
        # (e.g. waiting for freshly-deployed machines to become SSHable before
        # proxmox.install). If the test fails and retries remain, the test
        # playbook should reset machine state so the retry apply re-provisions.
        wave_attempt  = 0
        wave_pass     = False
        wave_failures = []

        while wave_attempt <= max_retries:
            if wave_attempt > 0:
                if retry_delay > 0:
                    print(f'\n--- [{name}] retry {wave_attempt}/{max_retries} (waiting {retry_delay}s) ---')
                    time.sleep(retry_delay)
                else:
                    print(f'\n--- [{name}] retry {wave_attempt}/{max_retries} ---')

            # ── pre-apply: clear stale GCS locks for this wave's units ──
            if pre_apply_unlock and gcs_bucket:
                unlock_wave_locks(name, gcs_bucket, get_wave_unit_prefixes(cfg, name))

            # ── pre-run hook ──
            if pre_pb:
                try:
                    run_ansible_playbook(pre_pb, name, 'precheck', log_dir)
                except subprocess.CalledProcessError as e:
                    if wave_attempt < max_retries:
                        _warn(f'[{name}] precheck failed (attempt {wave_attempt + 1}/{max_retries + 1}) — will retry')
                        wave_attempt += 1
                        continue
                    elif not ignore:
                        raise
                    else:
                        _warn(f'[{name}] precheck failed (exit {e.returncode}) — continuing')
                        wave_failures.append(f'{name}:precheck')

            # ── apply ──
            apply_ok = True
            try:
                run_tg('apply', name, log_dir)
            except subprocess.CalledProcessError as e:
                if not ignore and wave_attempt >= max_retries:
                    raise
                _warn(f'[{name}] apply failed (exit {e.returncode}) — skipping inventory/test for this wave')
                wave_failures.append(f'{name}:apply')
                apply_ok = False

            # ── inventory update (skip if apply failed) ──
            if update_inv and apply_ok:
                try:
                    update_inventory(name, log_dir, partial=partial_run)
                except subprocess.CalledProcessError as e:
                    if not ignore:
                        raise
                    _warn(f'[{name}] inventory update failed (exit {e.returncode}) — continuing')
                    wave_failures.append(f'{name}:inventory')

            # ── test phase (skip if apply failed) ──
            test_ok = True
            if not args.skip_test and apply_ok:
                try:
                    if test_pb:
                        run_ansible_playbook(test_pb, name, 'test-playbook', log_dir)
                    elif test_action == 'reapply':
                        print(f'\n--- [{name}] test: reapply (idempotency check) ---')
                        run_tg('apply', name, log_dir)
                except subprocess.CalledProcessError as e:
                    test_ok = False
                    if wave_attempt < max_retries:
                        _warn(f'[{name}] test failed (attempt {wave_attempt + 1}/{max_retries + 1}) — will retry wave')
                    elif not ignore:
                        raise
                    else:
                        _warn(f'[{name}] test failed (exit {e.returncode}) — continuing')
                        wave_failures.append(f'{name}:test')

            if apply_ok and test_ok:
                wave_pass = True
                break

            wave_attempt += 1

        if not wave_pass:
            failures.extend(wave_failures)

    if failures:
        print(f'\n=== lab-stack complete — {len(failures)} failure(s) ===')
        for f in failures:
            print(f'  FAIL: {f}', file=sys.stderr)
        sys.exit(1)

    print('\n=== lab-stack complete ===')


if __name__ == '__main__':
    try:
        main()
    except subprocess.CalledProcessError as e:
        print(f'\nERROR: command failed (exit {e.returncode})', file=sys.stderr)
        sys.exit(e.returncode)
    except KeyboardInterrupt:
        print('\nInterrupted.', file=sys.stderr)
        sys.exit(130)
