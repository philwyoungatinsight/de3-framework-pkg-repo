def run_tg(action: str, wave: str, log_dir: Path):
    log = log_dir / f'wave-{wave}-{action}.log'
    print(f'\n--- [{wave}] terragrunt {action} ---')
    _gcs_status.write_wave_status(wave, action, 'running')
    try:
        _stream(
            ['terragrunt', 'run', '--all', action, '--non-interactive'],
            extra_env={'TG_WAVE': wave, '_INVENTORY_WAVE': wave},
            cwd=INFRA_DIR,
            wave_log=log,
        )
    except Exception:
        _gcs_status.write_wave_status(wave, action, 'fail')
        raise
    _gcs_status.write_wave_status(wave, action, 'ok')
    print(f'--- [{wave}] {action} done ---')


def run_ansible_playbook(playbook: str, wave: str, phase: str, log_dir: Path):
    # Search for playbook in all packages' _wave_scripts/ directories
    path = None
    for pkg_dir in sorted(INFRA_DIR.iterdir()):
        candidate = pkg_dir / '_wave_scripts' / 'test-ansible-playbooks' / playbook / 'run'
        if candidate.is_file():
            path = candidate
            break
    if path is None:
        print(f'ERROR: playbook run not found for {playbook!r} under any infra/<pkg>/_wave_scripts/', file=sys.stderr)
        sys.exit(1)
    log = log_dir / f'wave-{wave}-{phase}.log'
    print(f'\n--- [{wave}] {phase}: {playbook} ---')
    _gcs_status.write_wave_status(wave, phase, 'running')
    try:
        _stream([str(path)], wave_log=log)
    except Exception:
        _gcs_status.write_wave_status(wave, phase, 'fail')
        raise
    _gcs_status.write_wave_status(wave, phase, 'ok')
    print(f'--- [{wave}] {phase} done ---')


def update_inventory(wave: str, log_dir: Path, *, partial: bool = False):
    if not GENERATE_INVENTORY.is_file():
        print(f'WARNING: generate-ansible-inventory not found — skipping')
        return
    # Partial run: pass the current wave name so SSH failures on hosts belonging
    # to other waves are downgraded to warnings (host stays in inventory).
    # Full run: no --wave filter — all hosts are checked strictly.
    extra = {'_INVENTORY_WAVE': wave} if partial else {}
    log = log_dir / f'wave-{wave}-inventory.log'
    print(f'\n--- [{wave}] update-inventory ({"partial" if partial else "full"}) ---')
    _stream([str(GENERATE_INVENTORY), '--build'], extra_env=extra, wave_log=log)
    print(f'--- [{wave}] update-inventory done ---')


