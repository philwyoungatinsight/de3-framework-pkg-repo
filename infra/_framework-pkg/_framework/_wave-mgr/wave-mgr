def get_gcs_bucket(cfg: dict) -> str:
    return cfg.get('backend', {}).get('config', {}).get('bucket', '')


def get_wave_unit_prefixes(cfg: dict, wave_name: str) -> list:
    """Return GCS path prefixes for config_params keys whose _wave matches wave_name.
    A parent-key prefix (e.g. unifi-pkg/_stack/unifi/pwy-homelab/) covers all child units."""
    prefixes = []
    for key, params in cfg.get('config_params', {}).items():
        if isinstance(params, dict) and params.get('_wave') == wave_name:
            prefixes.append(key + '/')
    for provider_cfg in cfg.get('providers', {}).values():
        for key, params in provider_cfg.get('config_params', {}).items():
            if isinstance(params, dict) and params.get('_wave') == wave_name:
                prefixes.append(key + '/')
    return prefixes


def unlock_all_gcs_locks(bucket: str):
    """Delete all .tflock files in the GCS bucket. Exits non-zero if gsutil fails."""
    if not bucket:
        print('ERROR: no GCS bucket configured', file=sys.stderr)
        sys.exit(1)
    result = subprocess.run(
        ['gsutil', 'ls', '-r', f'gs://{bucket}/'],
        capture_output=True, text=True, env=ENV,
    )
    if result.returncode != 0:
        print(f'ERROR: gsutil ls failed:\n{result.stderr}', file=sys.stderr)
        sys.exit(1)
    locks = [line.strip() for line in result.stdout.splitlines() if line.strip().endswith('.tflock')]
    if not locks:
        print('No GCS locks found.')
        return
    print(f'Removing {len(locks)} lock(s):')
    for lock in locks:
        print(f'  {lock}')
    subprocess.run(['gsutil', '-m', 'rm'] + locks, env=ENV, check=True)
    print('Done.')


def unlock_wave_locks(wave_name: str, bucket: str, prefixes: list):
    """Delete stale GCS lock files for units in the given wave. Best-effort (non-fatal)."""
    if not bucket or not prefixes:
        return
    try:
        result = subprocess.run(
            ['gsutil', 'ls', '-r', f'gs://{bucket}/'],
            capture_output=True, text=True, env=ENV,
        )
        if result.returncode != 0:
            return
        base = f'gs://{bucket}/'
        to_delete = [
            line.strip()
            for line in result.stdout.splitlines()
            if line.strip().endswith('.tflock')
            and any(line.strip()[len(base):].startswith(p) for p in prefixes)
        ]
        if to_delete:
            print(f'\n--- [{wave_name}] unlock: removing {len(to_delete)} stale lock(s) ---')
            subprocess.run(['gsutil', '-m', 'rm'] + to_delete, env=ENV, check=False)
    except Exception:
        pass  # never block apply


